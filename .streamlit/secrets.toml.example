# Streamlit Cloud secrets template.
# Paste the filled-in version into your app's Settings -> Secrets on
# share.streamlit.io. DO NOT commit the real secrets.toml (it is gitignored).
# Streamlit exposes these to the app via both st.secrets and os.environ,
# so the existing os.getenv(...) calls will resolve them.

OPENAI_API_KEY = ""
ANTHROPIC_API_KEY = ""
COHERE_API_KEY = ""
cohere_api_key = ""
cohere_classification_api_key = ""
pinecone_api_key = ""
llama_parser_api_key = ""
LLAMA_INDEX_API_KEY = ""
ELEVENLABS_API_KEY = ""
together_ai_api_key = ""
SERAPI_API_KEY = ""

SNOWFLAKE_ADMIN_TOKEN = ""
SNOWFLAKE_USER_ROLE = ""

factset_key = ""
factset_keyId = ""
factset_counter = ""
factset_username = ""
factset_serial = ""

# AWS Secrets Manager access (utils/secrets_retrieval.py reads secret
# "document_pipeline" in us-east-1 via the boto3 default credential chain).
AWS_ACCESS_KEY_ID = ""
AWS_SECRET_ACCESS_KEY = ""
AWS_DEFAULT_REGION = "us-east-1"
