# Copy to .env and fill in real values for local development.
# On Streamlit Cloud, set these in the app's Secrets dashboard instead
# (Streamlit exposes secrets as both st.secrets and environment variables).
#
# AWS credentials are read from ~/.aws/credentials via the boto3 default
# chain locally. On Streamlit Cloud, set AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY
# (and AWS_DEFAULT_REGION) in Secrets so boto3 can reach Secrets Manager.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
COHERE_API_KEY=
cohere_api_key=
cohere_classification_api_key=
pinecone_api_key=
llama_parser_api_key=
LLAMA_INDEX_API_KEY=
ELEVENLABS_API_KEY=
together_ai_api_key=
SERAPI_API_KEY=

# Snowflake
SNOWFLAKE_ADMIN_TOKEN=
SNOWFLAKE_USER_ROLE=

# FactSet
factset_key=
factset_keyId=
factset_counter=
factset_username=
factset_serial=

# AWS (Streamlit Cloud only — local uses ~/.aws/credentials)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
